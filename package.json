{
  "name": "tech-at-work",
  "version": "1.0.0",
  "type": "module",
  "description": "Tech@Work — AI-Led Intelligence Scrollytelling Website",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run tailwind:watch\" \"npm run serve\"",
    "build": "npm run tailwind:build && node build.js",
    "tailwind:build": "tailwindcss -i css/input.css -o css/output.css",
    "tailwind:watch": "tailwindcss -i css/input.css -o css/output.css --watch",
    "serve": "serve . -l 3000 --cors"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "fluent-ffmpeg": "^2.1.3",
    "postcss": "^8.5.15",
    "serve": "^14.2.4",
    "sharp": "^0.35.0",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "resend": "^6.12.4"
  }
}
